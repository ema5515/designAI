            {i % 5 === 0 && (
              <text x={202 + i * 20} y="50" fontFamily="monospace" fontSize="6" fill="#333">{i * 20}</text>
            )}
          </g>
        ))}
        <rect x="200" y="52" width="16" height="528" fill="#131313" />
        {Array.from({ length: 26 }, (_, i) => (
          <g key={`rv${i}`}>

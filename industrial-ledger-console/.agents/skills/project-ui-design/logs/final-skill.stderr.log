#!/usr/bin/env node
/**
 * generate-design-skill.mjs
 *
 * Scopo:
 * - Analizza un repository frontend (Next.js/Tailwind/shadcn o simili)
 * - Usa Codex CLI per generare:
 *   1) foundation UI/UX più solida
 *   2) estrazione del design system del repo
 *   3) skill finale pronta da usare
 * - Crea una skill Codex locale in .agents/skills/<skill-name>/
 *
 * Migliorie principali:
 * - Usa `codex exec -o` per salvare l'ultimo messaggio in file
 * - Usa `--output-schema` per il JSON strutturato
 * - Rafforza estrazione e skill su:
 *   - radius
 *   - spacing
 *   - visual priority
 *   - hierarchy
 *   - interaction states
 *   - typography roles
 * - Gestisce anche componenti non presenti nel repo come pattern derivati
 *
 * Requisiti:
 * - Node.js 18+
 * - Git repository inizializzato
 * - Codex CLI installato e autenticato
 *
 * Uso:
 *   node generate-design-skill.mjs
 *
 * Variabili opzionali:
 *   DESIGN_SKILL_NAME="project-ui-design"
 *   DESIGN_SKILL_DISPLAY_NAME="Project UI Design"
 *   DESIGN_SKILL_DESCRIPTION="Generate UI consistent with this product style."
 *   CODEX_BIN="codex"
 *   DESIGN_SKILL_MODEL="gpt-5.2-codex"
 */

import fs from "node:fs";
import path from "node:path";
import os from "node:os";
import { spawnSync } from "node:child_process";

const cwd = process.cwd();

const CONFIG = {
  skillName: sanitizeSkillName(
    process.env.DESIGN_SKILL_NAME || "project-ui-design"
  ),
  displayName:
    process.env.DESIGN_SKILL_DISPLAY_NAME || "Project UI Design",
  description:
    process.env.DESIGN_SKILL_DESCRIPTION ||
    "Generate UI consistent with the existing product style, structure, and UX rules.",
  codexBin: process.env.CODEX_BIN || "codex",
  model: process.env.DESIGN_SKILL_MODEL || "gpt-5.4",
};

const ROOT = cwd;
const SKILL_ROOT = path.join(ROOT, ".agents", "skills", CONFIG.skillName);
const INPUT_DIR = path.join(SKILL_ROOT, "input");
const OUTPUT_DIR = path.join(SKILL_ROOT, "outputs");
const ASSETS_DIR = path.join(SKILL_ROOT, "assets");
const LOGS_DIR = path.join(SKILL_ROOT, "logs");
const AGENTS_DIR = path.join(SKILL_ROOT, "agents");

main();

function main() {
  try {
    ensureGitRepo();
    ensureCodexExists();

    log(`Creating skill folder: ${rel(SKILL_ROOT)}`);
    mkdirp(SKILL_ROOT);
    mkdirp(INPUT_DIR);
    mkdirp(OUTPUT_DIR);
    mkdirp(ASSETS_DIR);
    mkdirp(LOGS_DIR);
    mkdirp(AGENTS_DIR);

    const repoInventory = buildRepoInventory(ROOT);
    writeSupportFiles(repoInventory);

    runFoundationGeneration();
    runDesignExtraction(repoInventory);
    runFinalSkillGeneration();

    writeTopLevelSkillFile();
    writeOpenAIConfigFile();
    writeReadmeFile(repoInventory);

    log("");
    log("Done.");
    log(`Skill created in: ${rel(SKILL_ROOT)}`);
    log(`Main skill file: ${rel(path.join(SKILL_ROOT, "SKILL.md"))}`);
    log("");
    log("Suggested usage in Codex:");
    log(`  $${CONFIG.skillName}`);
  } catch (error) {
    console.error("");
    console.error("[design-skill] Failed:");
    console.error(error instanceof Error ? error.message : String(error));
    process.exit(1);
  }
}


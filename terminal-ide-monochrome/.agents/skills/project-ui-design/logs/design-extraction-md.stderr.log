.ascii-pulse {
  animation: ascii-pulse 2s ease-in-out infinite;
}

.ascii-slide {
  animation: ascii-slide 3s ease-in-out infinite;
}

.ascii-rotate {
  animation: ascii-rotate 4s linear infinite;
}

.ascii-bounce {
  animation: ascii-bounce 2s infinite;
}

/* Added slow spin animation for SVG elements */
@keyframes spin-slow {
  from {
    transform: rotate(0deg);
  }
  to {
    transform: rotate(360deg);
  }
}

.animate-spin-slow {
  animation: spin-slow 3s linear infinite;
}

/* Enhanced hover effects for better interactivity with grey colors only */
@keyframes pulse-glow {
  0%,
  100% {
    box-shadow: 0 0 5px rgba(255, 255, 255, 0.3);
  }
  50% {
    box-shadow: 0 0 20px rgba(255, 255, 255, 0.6), 0 0 30px rgba(255, 255, 255, 0.4);
  }
}

.hover-glow:hover {
  animation: pulse-glow 1.5s ease-in-out infinite;
}

/* Enhanced matrix background animation */
@keyframes matrix-flow {
  0% {
    transform: translateY(-20px);
    opacity: 0;
  }
  10% {
    opacity: 1;
  }
  90% {
    opacity: 1;
  }
  100% {
    transform: translateY(20px);
    opacity: 0;
  }
}

.matrix-flow {
  animation: matrix-flow 4s linear infinite;
}

/* Custom scrollbar styling for black/grey terminal theme */
::-webkit-scrollbar {
  width: 8px;
}

::-webkit-scrollbar-track {
  background: #000000;
}

::-webkit-scrollbar-thumb {
  background: #404040;
  border-radius: 4px;
}

::-webkit-scrollbar-thumb:hover {
  background: #606060;
}

/* Terminal-specific utility classes */
.terminal-border {
  border: 1px solid #404040;
  box-shadow: 0 0 10px rgba(255, 255, 255, 0.1);
}

.terminal-bg {
  background: linear-gradient(135deg, #0a0a0a 0%, #1a1a1a 100%);
}

.terminal-text {
  font-family: "Courier New", "Monaco", "Menlo", monospace;
  letter-spacing: 0.5px;
}

/* Enhanced responsive grid for matrix background with more density */
.grid-cols-20 {
  grid-template-columns: repeat(20, minmax(0, 1fr));
}

.grid-cols-25 {
  grid-template-columns: repeat(25, minmax(0, 1fr));
}

@media (min-width: 768px) {
  .grid-cols-20 {
    grid-template-columns: repeat(30, minmax(0, 1fr));
  }
  .grid-cols-25 {
    grid-template-columns: repeat(35, minmax(0, 1fr));
  }
}

@media (min-width: 1024px) {
  .grid-cols-20 {
    grid-template-columns: repeat(40, minmax(0, 1fr));
  }
  .grid-cols-25 {
    grid-template-columns: repeat(50, minmax(0, 1fr));
  }
}

/* Enhanced button hover effects for terminal theme */
.btn-terminal {
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.btn-terminal:hover {
  box-shadow: 0 0 20px rgba(255, 255, 255, 0.3);
  border-color: rgba(255, 255, 255, 0.5);
}

.btn-terminal::before {
  content: "";
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
  transition: left 0.5s;
}

.btn-terminal:hover::before {
  left: 100%;
}

/* Enhanced card hover effects with better shadows */
.card-interactive {
  transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  cursor: pointer;
}

.card-interactive:hover {
  transform: translateY(-8px);
  box-shadow: 0 20px 40px rgba(255, 255, 255, 0.15), 0 0 0 1px rgba(255, 255, 255, 0.3), inset 0 1px 0

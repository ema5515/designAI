  background: linear-gradient(145deg, #1a1a1a 0%, #2a2a2a 50%, #1a1a1a 100%);
}

/* Added ASCII art specific hover effects */
.ascii-hover:hover {
  text-shadow: 0 0 15px rgba(255, 255, 255, 0.9), 0 0 25px rgba(255, 255, 255, 0.6);
  transition: all 0.3s ease;
}

.ascii-container:hover .ascii-art {
  animation: ascii-pulse 1s ease-in-out infinite;
}

/* Terminal window effects */
.terminal-window {
